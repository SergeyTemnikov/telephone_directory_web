@using PhoneDirectoryBlazor.Models
@using PhoneDirectoryBlazor.Services.Api
@using MudBlazor
@inject IAdminClient AdminClient
@inject IApiErrorHandler ErrorHandler
@inject ISnackbar Snackbar

<Modal IsVisible="@IsVisible" IsVisibleChanged="OnIsVisibleChanged">
    <MudPaper Class="pa-4">
        <MudText Typo="Typo.h6">@Title</MudText>

        <MudForm @ref="_form" Class="mt-3">
            <MudTextField @bind-Value="editName"
                          Label="Название"
                          For="@(() => editName)"
                          Required="true"
                          MaxLength="50"
                          HelperText="Максимум 50 символов" />

            <MudSelect T="int?" Label="Родитель"
                       @bind-Value="selectedParentId"
                       Clearable="true"
                       Searchable="true"
                       PopoverClass="my-dept-popover">
                <MudSelectItem T="int?" Value="null">— Нет родителя —</MudSelectItem>
                @foreach (var d in Departments ?? Enumerable.Empty<DepartmentViewModel>())
                {
                    if (Model?.Id != null && d.Id == Model.Id) continue;
                    <MudSelectItem T="int?" Value="@d.Id">@d.Name</MudSelectItem>
                }
            </MudSelect>

            <div class="d-flex justify-end gap-2 mt-4">
                <MudButton Variant="Variant.Text" OnClick="Cancel">Отмена</MudButton>
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           OnClick="SaveAsync"
                           Disabled="@_saving">
                    @(_saving ? "Сохранение..." : "Сохранить")
                </MudButton>
            </div>
        </MudForm>
    </MudPaper>
</Modal>

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public EventCallback<bool> IsVisibleChanged { get; set; }
    [Parameter] public DepartmentViewModel? Model { get; set; }
    [Parameter] public List<DepartmentViewModel>? Departments { get; set; }
    [Parameter] public EventCallback<bool> OnSaved { get; set; }

    private MudForm? _form;
    private string editName = "";
    private int? selectedParentId;
    private bool _saving;
    private CancellationTokenSource? _cts;

    private string Title => IsCreateMode ? "Создать отдел" : "Редактировать отдел";
    private bool IsCreateMode => Model?.Id == null || Model.Id == 0;

    protected override void OnInitialized()
    {
        _cts = new CancellationTokenSource();
    }

    protected override void OnParametersSet()
    {
        editName = Model?.Name ?? string.Empty;
        selectedParentId = Model?.ParentId;
    }

    private async Task SaveAsync()
    {
        await (_form?.ValidateAsync() ?? Task.CompletedTask);
        if (_form != null && !_form.IsValid) return;

        if (string.IsNullOrWhiteSpace(editName))
        {
            Snackbar.Add("Введите название отдела", Severity.Warning);
            return;
        }

        if (!IsCreateMode && selectedParentId == Model?.Id)
        {
            Snackbar.Add("Нельзя выбрать отдел в качестве собственного родителя", Severity.Warning);
            return;
        }

        _saving = true;
        StateHasChanged();

        try
        {
            if (IsCreateMode)
            {
                var req = new CreateDepartmentRequest { Name = editName, Parent_department_id = selectedParentId };
                await AdminClient.DepartmentsPostAsync(req, _cts.Token);
            }
            else if (Model?.Id.HasValue == true)
            {
                var req = new UpdateDepartmentRequest { Name = editName, Parent_department_id = selectedParentId };
                await AdminClient.DepartmentsPutAsync(Model.Id.Value, req, _cts.Token);
            }

            if (IsVisible && OnSaved.HasDelegate)
            {
                await OnSaved.InvokeAsync(true);
            }
            await CloseModalAsync();
        }
        catch (OperationCanceledException)
        {
        }
        catch (ApiException aex) when (IsVisible)
        {
            var userMessage = ErrorHandler.GetErrorMessage(aex);
            Snackbar.Add(userMessage, Severity.Error, config => config.VisibleStateDuration = 6000);
        }
        catch (Exception ex) when (IsVisible)
        {
            Snackbar.Add($"Неожиданная ошибка: {ex.Message}", Severity.Error);
        }
        finally
        {
            _saving = false;
            if (IsVisible)
            {
                try { StateHasChanged(); }
                catch (ObjectDisposedException) { }
            }
        }
    }

    private async Task Cancel()
    {
        if (!IsVisible) return;
        if (OnSaved.HasDelegate) await OnSaved.InvokeAsync(false);
        await CloseModalAsync();
    }

    private async Task CloseModalAsync()
    {
        if (!IsVisible) return;
        IsVisible = false;
        if (IsVisibleChanged.HasDelegate) await IsVisibleChanged.InvokeAsync(IsVisible);
    }

    private Task OnIsVisibleChanged(bool visible)
    {
        if (!visible && OnSaved.HasDelegate) OnSaved.InvokeAsync(false);
        return Task.CompletedTask;
    }

    public void Dispose()
    {
        _cts?.Dispose();
    }
}