@page "/admin/positions"
@inject IAdminClient AdminClient
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<MudStack Spacing="2">
    <MudText Typo="Typo.h5">Позиции</MudText>

    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="OpenCreate">
        <MudIcon Icon="@Icons.Material.Filled.Add" Class="mr-2" />
        Добавить позицию
    </MudButton>

    <MudTable Items="@_sortedItems" Hover="true" Bordered="true" Striped="true">
        <HeaderContent>
            <MudTh @onclick="() => ToggleSort(nameof(PositionViewModel.Id))" Style="cursor:pointer;">
                Id
                @SortIcon(nameof(PositionViewModel.Id))
            </MudTh>
            <MudTh @onclick="() => ToggleSort(nameof(PositionViewModel.Name))" Style="cursor:pointer;">
                Название
                @SortIcon(nameof(PositionViewModel.Name))
            </MudTh>
            <MudTh>Действия</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Id">@context.Id</MudTd>
            <MudTd DataLabel="Название">@context.Name</MudTd>
            <MudTd DataLabel="Действия">
                <MudButton Size="Size.Small" Variant="Variant.Text" OnClick="(() => OpenEdit(context))">
                    Редактировать
                </MudButton>
                <MudButton Size="Size.Small" Color="Color.Error" Variant="Variant.Text" OnClick="(() => Delete(context))">
                    Удалить
                </MudButton>
            </MudTd>
        </RowTemplate>
        <PagerContent>
            <MudTablePager PageSizeOptions="new int[] { 10, 25, 50 }" />
        </PagerContent>
    </MudTable>
</MudStack>

<EditPositionDialog IsVisible="@isEditModalVisible"
                    IsVisibleChanged="@(async v => isEditModalVisible = v)"
                    Model="@editingModel"
                    OnSaved="OnEditSaved" />

@code {
    private List<PositionViewModel> _items = new();
    private bool isEditModalVisible;
    private PositionViewModel? editingModel;

    private string _sortedColumn = null;
    private SortDirection _sortDirection = SortDirection.None;
    private Func<PositionViewModel, object>? _sortBy;
    private IEnumerable<PositionViewModel> _sortedItems => ApplySorting(_items);

    protected override async Task OnInitializedAsync()
    {
        await LoadItems();
    }

    private async Task LoadItems()
    {
        try
        {
            var resp = await AdminClient.PositionsGetAsync();
            var data = resp?.Data ?? new List<PositionResponse>();

            _items = data.Select(p => new PositionViewModel
            {
                Id = p.Id,
                Name = p.Name ?? string.Empty
            }).ToList();

            _sortedColumn = null;
            _sortDirection = SortDirection.None;
            _sortBy = null;
        }
        catch (ApiException aex)
        {
            Snackbar.Add($"Ошибка API: {aex.Message}", Severity.Error);
            _items = new List<PositionViewModel>();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Ошибка загрузки: {ex.Message}", Severity.Error);
            _items = new List<PositionViewModel>();
        }
    }

    private IEnumerable<PositionViewModel> ApplySorting(List<PositionViewModel> items)
    {
        if (_sortBy == null || _sortDirection == SortDirection.None) return items;
        return _sortDirection == SortDirection.Ascending ? items.OrderBy(_sortBy) : items.OrderByDescending(_sortBy);
    }

    private void ToggleSort(string propertyName)
    {
        if (_sortedColumn == propertyName)
        {
            switch (_sortDirection)
            {
                case SortDirection.None:
                    _sortDirection = SortDirection.Ascending;
                    break;
                case SortDirection.Ascending:
                    _sortDirection = SortDirection.Descending;
                    break;
                case SortDirection.Descending:
                    _sortDirection = SortDirection.None;
                    break;
            }
        }
        else
        {
            _sortedColumn = propertyName;
            _sortDirection = SortDirection.Ascending;
        }

        _sortBy = _sortDirection switch
        {
            SortDirection.Ascending or SortDirection.Descending => propertyName switch
            {
                nameof(PositionViewModel.Id) => item => item.Id ?? 0,
                nameof(PositionViewModel.Name) => item => item.Name ?? string.Empty,
                _ => null
            },
            _ => null
        };
        StateHasChanged();
    }

    private RenderFragment SortIcon(string propertyName) => builder =>
    {
        if (_sortedColumn != propertyName) return;

        var icon = _sortDirection switch
        {
            SortDirection.Ascending => Icons.Material.Filled.ArrowUpward,
            SortDirection.Descending => Icons.Material.Filled.ArrowDownward,
            _ => Icons.Material.Filled.UnfoldMore
        };

        builder.OpenComponent<MudIcon>(0);
        builder.AddAttribute(1, "Icon", icon);
        builder.AddAttribute(2, "Style", "margin-left: 8px; font-size: 1rem; vertical-align: middle;");
        builder.CloseComponent();
    };

    private Task OpenCreate()
    {
        editingModel = new PositionViewModel();
        isEditModalVisible = true;
        return Task.CompletedTask;
    }

    private Task OpenEdit(PositionViewModel item)
    {
        editingModel = new PositionViewModel
        {
            Id = item.Id,
            Name = item.Name
        };
        isEditModalVisible = true;
        return Task.CompletedTask;
    }

    private async Task OnEditSaved(bool saved)
    {
        isEditModalVisible = false;
        if (saved)
        {
            await LoadItems();
            Snackbar.Add("Сохранено", Severity.Success);
        }
    }

    private async Task Delete(PositionViewModel item)
    {
        bool? confirm = await DialogService.ShowMessageBoxAsync(
            "Подтвердите",
            $"Удалить позицию «{item.Name}»?",
            yesText: "Да",
            noText: "Нет");

        if (confirm == true)
        {
            try
            {
                if (item.Id.HasValue)
                {
                    await AdminClient.PositionsDeleteAsync(item.Id.Value);
                    await LoadItems();
                    Snackbar.Add("Удалено", Severity.Success);
                }
            }
            catch (ApiException ex)
            {
                if (ex.StatusCode == 409)
                {
                    Snackbar.Add("Невозможно удалить: позиция назначена сотрудникам", Severity.Warning);
                }
                else
                {
                    Snackbar.Add($"Ошибка удаления: {ex.Message}", Severity.Error);
                }
            }
        }
    }
}