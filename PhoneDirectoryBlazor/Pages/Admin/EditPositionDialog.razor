@inject IAdminClient AdminClient
@inject IApiErrorHandler ErrorHandler
@inject ISnackbar Snackbar

<Modal IsVisible="@IsVisible" IsVisibleChanged="OnIsVisibleChanged">
    <MudPaper Class="pa-4" Style="min-width:400px;">
        <MudText Typo="Typo.h6">@Title</MudText>

        <MudForm @ref="_form" Class="mt-3">
            <MudTextField @bind-Value="editName"
                          Label="Название позиции"
                          For="@(() => editName)"
                          Required="true"
                          HelperText="Например: Старший разработчик, Менеджер проектов" />

            <div class="d-flex justify-end gap-2 mt-4">
                <MudButton Variant="Variant.Text" OnClick="Cancel">Отмена</MudButton>
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           OnClick="SaveAsync"
                           Disabled="@_saving">
                    @(_saving ? "Сохранение..." : "Сохранить")
                </MudButton>
            </div>
        </MudForm>
    </MudPaper>
</Modal>

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public EventCallback<bool> IsVisibleChanged { get; set; }
    [Parameter] public PositionViewModel? Model { get; set; }
    [Parameter] public EventCallback<bool> OnSaved { get; set; }

    private MudForm? _form;
    private string editName = "";
    private bool _saving;
    private CancellationTokenSource? _cts;

    private string Title => IsCreateMode ? "Создать позицию" : "Редактировать позицию";
    private bool IsCreateMode => Model?.Id == null || Model.Id == 0;

    protected override void OnInitialized()
    {
        _cts = new CancellationTokenSource();
    }

    protected override void OnParametersSet()
    {
        editName = Model?.Name ?? string.Empty;
    }

    private async Task SaveAsync()
    {
        await (_form?.ValidateAsync() ?? Task.CompletedTask);
        if (_form != null && !_form.IsValid) return;

        if (string.IsNullOrWhiteSpace(editName))
        {
            Snackbar.Add("Введите название позиции", Severity.Warning);
            return;
        }

        _saving = true;
        StateHasChanged();

        try
        {
            if (IsCreateMode)
            {
                var req = new CreatePositionRequest { Name = editName };
                await AdminClient.PositionsPostAsync(req, _cts.Token);
            }
            else if (Model?.Id.HasValue == true)
            {
                var req = new UpdatePositionRequest { Name = editName };
                await AdminClient.PositionsPutAsync(Model.Id.Value, req, _cts.Token);
            }

            if (IsVisible && OnSaved.HasDelegate)
            {
                await OnSaved.InvokeAsync(true);
            }
            await CloseModalAsync();
        }
        catch (OperationCanceledException)
        {
        }
        catch (ApiException aex) when (IsVisible)
        {
            var userMessage = ErrorHandler.GetErrorMessage(aex);
            Snackbar.Add(userMessage, Severity.Error, config => config.VisibleStateDuration = 6000);
        }
        catch (Exception ex) when (IsVisible)
        {
            Snackbar.Add($"Неожиданная ошибка: {ex.Message}", Severity.Error);
        }
        finally
        {
            _saving = false;
            if (IsVisible)
            {
                try { StateHasChanged(); }
                catch (ObjectDisposedException) { }
            }
        }
    }

    private async Task Cancel()
    {
        if (!IsVisible) return;
        if (OnSaved.HasDelegate) await OnSaved.InvokeAsync(false);
        await CloseModalAsync();
    }

    private async Task CloseModalAsync()
    {
        if (!IsVisible) return;
        IsVisible = false;
        if (IsVisibleChanged.HasDelegate) await IsVisibleChanged.InvokeAsync(IsVisible);
    }

    private Task OnIsVisibleChanged(bool visible)
    {
        if (!visible && OnSaved.HasDelegate) OnSaved.InvokeAsync(false);
        return Task.CompletedTask;
    }

    public void Dispose()
    {
        _cts?.Dispose();
    }
}