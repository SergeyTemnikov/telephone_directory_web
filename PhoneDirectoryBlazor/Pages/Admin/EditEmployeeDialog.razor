@inject IAdminClient AdminClient
@inject IEmployeesClient EmployeesClient
@inject IApiErrorHandler ErrorHandler
@inject ISnackbar Snackbar

<Modal IsVisible="@IsVisible" IsVisibleChanged="OnIsVisibleChanged">
    <MudPaper Class="pa-4">
        <MudText Typo="Typo.h6">@Title</MudText>

        <MudForm @ref="_form" Class="mt-3">
            <MudTextField @bind-Value="editFullName" Label="ФИО" Required="true" />
            <MudTextField @bind-Value="editEmail" Label="Email" Required="true" Type="InputType.Email" />
            <MudTextField @bind-Value="editAddress" Label="Адрес" HelperText="Минимум 5 символов" />
            <MudTextField @bind-Value="editComment" Label="Комментарий" MaxLength="150" />

            <MudSelect T="int?" Label="Отдел" @bind-Value="selectedDepartmentId" Clearable="true" Searchable="true">
                <MudSelectItem T="int?" Value="null">— Не указан —</MudSelectItem>
                @foreach (var d in Departments ?? Enumerable.Empty<DepartmentViewModel>())
                {
                    <MudSelectItem T="int?" Value="@d.Id">@d.Name</MudSelectItem>
                }
            </MudSelect>

            <MudSelect T="int?" Label="Менеджер" @bind-Value="selectedManagerId" Clearable="true" Searchable="true">
                <MudSelectItem T="int?" Value="null">— Нет менеджера —</MudSelectItem>
                @foreach (var e in Employees ?? Enumerable.Empty<EmployeeViewModel>())
                {
                    if (Model?.Id != null && e.Id == Model.Id) continue;
                    <MudSelectItem T="int?" Value="@e.Id">@e.FullName</MudSelectItem>
                }
            </MudSelect>

            <MudSelect T="int?"
                       @key="@($"{_positions.Count}-{string.Join(",", selectedPositionIds ?? [])}")"
                       Label="Должности"
                       MultiSelection="true"
                       Searchable="true"
                       ToStringFunc="@(id => GetPositionName(id))"
                       SelectedValues="selectedPositionIds"
                       SelectedValuesChanged="OnSelectedPositionsChanged">
                @foreach (var p in _positions)
                {
                    <MudSelectItem T="int?" Value="@((int?)p.Id)">@p.Name</MudSelectItem>
                }
            </MudSelect>

            <MudTextField @bind-Value="phonesText"
                          Label="Телефоны (через запятую)"
                          HelperText="Например: +7 (999) 123-45-67, +7 (495) 000-00-00" />

            <div class="d-flex justify-end gap-2 mt-4">
                <MudButton Variant="Variant.Text" OnClick="Cancel">Отмена</MudButton>
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           OnClick="SaveAsync"
                           Disabled="@_saving">
                    @(_saving ? "Сохранение..." : "Сохранить")
                </MudButton>
            </div>
        </MudForm>
    </MudPaper>
</Modal>

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public EventCallback<bool> IsVisibleChanged { get; set; }
    [Parameter] public EmployeeViewModel? Model { get; set; }
    [Parameter] public List<DepartmentViewModel>? Departments { get; set; }
    [Parameter] public List<EmployeeViewModel>? Employees { get; set; }
    [Parameter] public EventCallback<bool> OnSaved { get; set; }

    private MudForm? _form;
    private string editFullName = "";
    private string editEmail = "";
    private string editAddress = "";
    private string editComment = "";
    private int? selectedDepartmentId;
    private int? selectedManagerId;
    private IReadOnlyCollection<int?> selectedPositionIds = new HashSet<int?>();
    private string phonesText = "";

    private bool _saving;
    private List<PositionResponse> _positions = new();
    private CancellationTokenSource? _cts;

    private string Title => IsCreateMode ? "Создать сотрудника" : "Редактировать сотрудника";
    private bool IsCreateMode => Model?.Id == null || Model.Id == 0;

    protected override void OnInitialized()
    {
        _cts = new CancellationTokenSource();
    }

    protected override async Task OnParametersSetAsync()
    {
        await LoadPositions();

        editFullName = Model?.FullName ?? string.Empty;
        editEmail = Model?.Email ?? string.Empty;
        editAddress = Model?.Address ?? string.Empty;
        editComment = Model?.Comment ?? string.Empty;
        selectedDepartmentId = Model?.DepartmentId;
        selectedManagerId = Model?.ManagerId;

        phonesText = Model != null ? string.Join(", ", Model.Phones) : string.Empty;

        if (Model?.Id.HasValue == true)
        {
            try
            {
                var resp = await EmployeesClient.PositionsGetAsync(Model.Id.Value, _cts.Token);

                selectedPositionIds = resp?.Data?
                    .Where(p => p.Id.HasValue)
                    .Select(p => (int?)p.Id!.Value)
                    .ToHashSet()
                    ?? new HashSet<int?>();
            }
            catch
            {
                selectedPositionIds = new HashSet<int?>();
            }
        }
        else
        {
            selectedPositionIds = new HashSet<int?>();
        }

        await InvokeAsync(StateHasChanged);
    }

    private Task OnSelectedPositionsChanged(IEnumerable<int?> values)
    {
        selectedPositionIds = values?.ToHashSet() ?? new HashSet<int?>();
        return Task.CompletedTask;
    }

    private async Task LoadPositions()
    {
        try
        {
            var resp = await AdminClient.PositionsGetAsync();
            _positions = resp?.Data?.ToList() ?? new List<PositionResponse>();
        }
        catch
        {
            _positions = new List<PositionResponse>();
        }
    }

    private string GetPositionName(int? id)
    {
        if (!id.HasValue) return string.Empty;
        var position = _positions.FirstOrDefault(p => p.Id == id.Value);
        return position?.Name ?? $"ID: {id}";
    }

    private async Task SaveAsync()
    {
        await (_form?.ValidateAsync() ?? Task.CompletedTask);
        if (_form != null && !_form.IsValid) return;

        if (string.IsNullOrWhiteSpace(editFullName) || string.IsNullOrWhiteSpace(editEmail))
        {
            Snackbar.Add("Введите ФИО и Email", Severity.Warning);
            return;
        }

        _saving = true;
        StateHasChanged();

        try
        {
            var phones = phonesText?.Split(',', StringSplitOptions.RemoveEmptyEntries)
                                   .Select(p => p.Trim())
                                   .Where(p => !string.IsNullOrWhiteSpace(p))
                                   .ToList() ?? new List<string>();

            var positionIds = selectedPositionIds
                .Where(id => id.HasValue)
                .Select(id => id.Value)
                .ToList();

            if (IsCreateMode)
            {
                var req = new CreateEmployeeRequest
                {
                    Full_name = editFullName,
                    Email = editEmail,
                    Address = editAddress,
                    Comment = editComment,
                    Department_id = selectedDepartmentId,
                    Manager_id = selectedManagerId,
                    Phones = phones,
                    Position_ids = positionIds
                };
                await AdminClient.EmployeesPostAsync(req, _cts.Token);
            }
            else if (Model?.Id.HasValue == true)
            {
                var employeeId = Model.Id.Value;

                var updateReq = new UpdateEmployeeRequest
                {
                    Full_name = editFullName,
                    Email = editEmail,
                    Address = editAddress,
                    Comment = editComment,
                    Department_id = selectedDepartmentId,
                    Manager_id = selectedManagerId
                };
                await AdminClient.EmployeesPutAsync(employeeId, updateReq, _cts.Token);

                await SyncPositionsAsync(employeeId, positionIds);
                await SyncPhonesAsync(employeeId, phones);
            }

            if (IsVisible && OnSaved.HasDelegate)
                await OnSaved.InvokeAsync(true);

            await CloseModalAsync();
        }
        catch (ApiException aex) when (IsVisible)
        {
            Snackbar.Add(ErrorHandler.GetErrorMessage(aex), Severity.Error);
        }
        catch (Exception ex) when (IsVisible)
        {
            Snackbar.Add($"Ошибка: {ex.Message}", Severity.Error);
        }
        finally
        {
            _saving = false;
            if (IsVisible) StateHasChanged();
        }
    }

    private async Task SyncPositionsAsync(int employeeId, List<int> desiredPositionIds)
    {
        try
        {
            var currentResp = await EmployeesClient.PositionsGetAsync(employeeId, _cts.Token);
            var currentIds = currentResp?.Data?
                .Where(p => p.Id.HasValue)
                .Select(p => p.Id!.Value)
                .ToHashSet() ?? new HashSet<int>();

            var desiredSet = new HashSet<int>(desiredPositionIds);

            foreach (var id in desiredSet.Except(currentIds))
                await EmployeesClient.PositionsPutAsync(employeeId, id, _cts.Token);

            foreach (var id in currentIds.Except(desiredSet))
                await EmployeesClient.PositionsDeleteAsync(employeeId, id, _cts.Token);
        }
        catch
        {
            Snackbar.Add("Ошибка синхронизации должностей", Severity.Warning);
        }
    }

    private async Task SyncPhonesAsync(int employeeId, List<string> phones)
    {
        try
        {
            var resp = await EmployeesClient.PhonesAsync(employeeId, _cts.Token);
            var current = resp?.Data ?? new List<PhoneResponse>();

            var currentNumbers = current.Select(p => p.Phone_number).ToHashSet();
            var desired = phones.ToHashSet();

            foreach (var p in current.Where(p => !desired.Contains(p.Phone_number)))
                await AdminClient.PhonesDeleteAsync(p.Id!.Value, _cts.Token);

            foreach (var p in desired.Except(currentNumbers))
                await AdminClient.PhonesPostAsync(new CreatePhoneRequest
                {
                    Employee_id = employeeId,
                    Phone_number = p
                }, _cts.Token);
        }
        catch
        {
            Snackbar.Add("Ошибка синхронизации телефонов", Severity.Warning);
        }
    }

    private async Task Cancel()
    {
        if (OnSaved.HasDelegate)
            await OnSaved.InvokeAsync(false);

        await CloseModalAsync();
    }

    private async Task CloseModalAsync()
    {
        IsVisible = false;
        if (IsVisibleChanged.HasDelegate)
            await IsVisibleChanged.InvokeAsync(IsVisible);
    }

    private Task OnIsVisibleChanged(bool visible)
    {
        if (!visible && OnSaved.HasDelegate)
            OnSaved.InvokeAsync(false);

        return Task.CompletedTask;
    }

    public void Dispose()
    {
        _cts?.Dispose();
    }
}