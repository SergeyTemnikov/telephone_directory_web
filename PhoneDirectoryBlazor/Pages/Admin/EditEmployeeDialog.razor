@using PhoneDirectoryBlazor.Models
@using PhoneDirectoryBlazor.Services.Api
@using MudBlazor
@inject IAdminClient AdminClient
@inject IEmployeesClient EmployeesClient
@inject ISnackbar Snackbar

<Modal IsVisible="@IsVisible" IsVisibleChanged="OnIsVisibleChanged">
    <MudPaper Class="pa-4">
        <MudText Typo="Typo.h6">@Title</MudText>

        <MudForm @ref="_form" Class="mt-3">
            <MudTextField @bind-Value="editFullName" Label="ФИО" For="@(() => editFullName)" Required="true" />
            <MudTextField @bind-Value="editEmail" Label="Email" For="@(() => editEmail)" Required="true" />
            <MudTextField @bind-Value="editAddress" Label="Адрес" For="@(() => editAddress)" />
            <MudTextField @bind-Value="editComment" Label="Комментарий" For="@(() => editComment)" />

            <MudSelect T="int?" Label="Отдел" @bind-Value="selectedDepartmentId" Clearable="true" Searchable="true">
                <MudSelectItem T="int?" Value="null">— Не указан —</MudSelectItem>
                @foreach (var d in Departments ?? Enumerable.Empty<DepartmentViewModel>())
                {
                    <MudSelectItem T="int?" Value="@d.Id">@d.Name (@d.Id)</MudSelectItem>
                }
            </MudSelect>

            <MudSelect T="int?" Label="Менеджер" @bind-Value="selectedManagerId" Clearable="true" Searchable="true">
                <MudSelectItem T="int?" Value="null">— Нет менеджера —</MudSelectItem>
                @foreach (var e in Employees ?? Enumerable.Empty<EmployeeViewModel>())
                {
                    if (Model?.Id != null && e.Id == Model.Id) continue;
                    <MudSelectItem T="int?" Value="@e.Id">@e.FullName (@e.Id)</MudSelectItem>
                }
            </MudSelect>

            <MudSelect T="int?"
                       Label="Позиции"
                       MultiSelection="true"
                       Searchable="true"
                       ToStringFunc="@(id => GetPositionName(id))"
                       @bind-SelectedValues="selectedPositionIds">
                @foreach (var p in _positions)
                {
                    <MudSelectItem T="int?" Value="@p.Id">@p.Name (@p.Id)</MudSelectItem>
                }
            </MudSelect>

            <MudTextField @bind-Value="phonesText" Label="Телефоны (через запятую)" For="@(() => phonesText)" />

            <div class="d-flex justify-end gap-2 mt-4">
                <MudButton Variant="Variant.Text" OnClick="Cancel">Отмена</MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveAsync" Disabled="@_saving">Сохранить</MudButton>
            </div>
        </MudForm>
    </MudPaper>
</Modal>

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public EventCallback<bool> IsVisibleChanged { get; set; }
    [Parameter] public EmployeeViewModel? Model { get; set; }
    [Parameter] public List<DepartmentViewModel>? Departments { get; set; }
    [Parameter] public List<EmployeeViewModel>? Employees { get; set; }
    [Parameter] public EventCallback<bool> OnSaved { get; set; }

    private MudForm? _form;
    private string editFullName = "";
    private string editEmail = "";
    private string editAddress = "";
    private string editComment = "";
    private int? selectedDepartmentId;
    private int? selectedManagerId;

    private IReadOnlyCollection<int?> selectedPositionIds = new HashSet<int?>();

    private string phonesText = "";
    private bool _saving;
    private List<PositionResponse> _positions = new();

    private string Title => (Model?.Id == null || Model.Id == 0) ? "Создать сотрудника" : "Редактировать сотрудника";

    protected override async Task OnParametersSetAsync()
    {
        editFullName = Model?.FullName ?? string.Empty;
        editEmail = Model?.Email ?? string.Empty;
        editAddress = Model?.Address ?? string.Empty;
        editComment = Model?.Comment ?? string.Empty;
        selectedDepartmentId = Model?.DepartmentId;
        selectedManagerId = Model?.ManagerId;

        if (Model?.Positions != null)
        {
            var ids = Model.Positions
                .Select(s => int.TryParse(s, out var id) ? (int?)id : null)
                .Where(i => i.HasValue)
                .ToList();
            selectedPositionIds = new HashSet<int?>(ids);
        }
        else
        {
            selectedPositionIds = new HashSet<int?>();
        }

        phonesText = Model != null ? string.Join(", ", Model.Phones) : string.Empty;

        await LoadPositions();
    }

    private async Task LoadPositions()
    {
        try
        {
            var resp = await AdminClient.PositionsGetAsync();
            _positions = resp?.Data?.ToList() ?? new List<PositionResponse>();
        }
        catch
        {
            _positions = new List<PositionResponse>();
        }
    }

    private async Task SaveAsync()
    {
        await (_form?.ValidateAsync() ?? Task.CompletedTask);
        if (_form != null && !_form.IsValid) return;

        if (string.IsNullOrWhiteSpace(editFullName) || string.IsNullOrWhiteSpace(editEmail))
        {
            Snackbar.Add("Введите ФИО и Email", Severity.Warning);
            return;
        }

        _saving = true;
        try
        {
            var phones = phonesText?.Split(',', StringSplitOptions.RemoveEmptyEntries)
                                   .Select(p => p.Trim())
                                   .Where(p => !string.IsNullOrWhiteSpace(p))
                                   .ToList() ?? new List<string>();

            var positionIds = selectedPositionIds
                .Where(id => id.HasValue)
                .Select(id => id.Value)
                .ToList();

            if (Model == null || Model.Id == null || Model.Id == 0)
            {
                var req = new CreateEmployeeRequest
                {
                    Full_name = editFullName,
                    Email = editEmail,
                    Address = editAddress,
                    Comment = editComment,
                    Department_id = selectedDepartmentId,
                    Manager_id = selectedManagerId,
                    Phones = phones,
                    Position_ids = positionIds
                };
                await AdminClient.EmployeesPostAsync(req);
            }
            else
            {
                var employeeId = Model.Id.Value;

                var updateReq = new UpdateEmployeeRequest
                {
                    Full_name = editFullName,
                    Email = editEmail,
                    Address = editAddress,
                    Comment = editComment,
                    Department_id = selectedDepartmentId,
                    Manager_id = selectedManagerId
                };
                await AdminClient.EmployeesPutAsync(employeeId, updateReq);

                try
                {
                    var currentPositionsResp = await EmployeesClient.PositionsGetAsync(employeeId);
                    var currentPositionIds = currentPositionsResp?.Data?
                        .Select(p => p.Id)
                        .Where(id => id.HasValue)
                        .Select(id => id!.Value)
                        .ToHashSet() ?? new HashSet<int>();

                    var desiredPositionIds = selectedPositionIds
                        .Where(id => id.HasValue)
                        .Select(id => id!.Value)
                        .ToHashSet();

                    var toAdd = desiredPositionIds.Except(currentPositionIds).ToList();
                    var toRemove = currentPositionIds.Except(desiredPositionIds).ToList();

                    foreach (var posId in toAdd)
                    {
                        try { await EmployeesClient.PositionsPutAsync(employeeId, posId); }
                        catch (ApiException aex) { Snackbar.Add($"Ошибка позиций: {aex.Message}", Severity.Warning); }
                    }

                    foreach (var posId in toRemove)
                    {
                        try { await EmployeesClient.PositionsDeleteAsync(employeeId, posId); }
                        catch (ApiException aex) { Snackbar.Add($"Ошибка позиций: {aex.Message}", Severity.Warning); }
                    }
                }
                catch (ApiException)
                {
                    Snackbar.Add("Не удалось синхронизировать позиции", Severity.Warning);
                }

                try
                {
                    var phonesResp = await EmployeesClient.PhonesAsync(employeeId);
                    var currentPhones = phonesResp?.Data?
                        .Where(p => p.Id.HasValue && !string.IsNullOrWhiteSpace(p.Phone_number))
                        .Select(p => new PhoneInfo { Id = p.Id!.Value, Number = p.Phone_number!.Trim() })
                        .ToList() ?? new List<PhoneInfo>();

                    var desiredPhones = phones
                        .Select(p => p.Trim())
                        .Where(p => !string.IsNullOrWhiteSpace(p))
                        .ToHashSet(StringComparer.OrdinalIgnoreCase);

                    var currentNumbers = currentPhones.Select(p => p.Number).ToHashSet(StringComparer.OrdinalIgnoreCase);

                    var toDelete = currentPhones.Where(cp => !desiredPhones.Contains(cp.Number)).Select(cp => cp.Id).ToList();
                    foreach (var phoneId in toDelete)
                    {
                        try { await AdminClient.PhonesDeleteAsync(phoneId); }
                        catch (ApiException aex) { Snackbar.Add($"Ошибка телефонов: {aex.Message}", Severity.Warning); }
                    }

                    var toAddPhones = desiredPhones.Except(currentNumbers).ToList();
                    foreach (var number in toAddPhones)
                    {
                        try
                        {
                            var createReq = new CreatePhoneRequest { Employee_id = employeeId, Phone_number = number };
                            await AdminClient.PhonesPostAsync(createReq);
                        }
                        catch (ApiException aex) { Snackbar.Add($"Ошибка телефонов: {aex.Message}", Severity.Warning); }
                    }
                }
                catch (ApiException)
                {
                    Snackbar.Add("Не удалось синхронизировать телефоны", Severity.Warning);
                }
            }

            await OnSaved.InvokeAsync(true);
            await CloseModalAsync();
        }
        catch (ApiException aex)
        {
            Snackbar.Add($"Ошибка API: {aex.Message}", Severity.Error);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Ошибка: {ex.Message}", Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }

    private string GetPositionName(int? id)
    {
        if (!id.HasValue) return string.Empty;

        var position = _positions.FirstOrDefault(p => p.Id == id.Value);
        return position?.Name ?? $"ID: {id}";
    }

    private async Task Cancel()
    {
        await OnSaved.InvokeAsync(false);
        await CloseModalAsync();
    }

    private async Task CloseModalAsync()
    {
        IsVisible = false;
        await IsVisibleChanged.InvokeAsync(IsVisible);
    }

    private Task OnIsVisibleChanged(bool visible)
    {
        if (!visible) OnSaved.InvokeAsync(false);
        return Task.CompletedTask;
    }
}