@page "/admin/departments"
@inject IAdminClient AdminClient
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<MudStack Spacing="2">
    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="OpenCreate">Добавить отдел</MudButton>

    <MudTable Items="@_sortedItems"
              Hover="true"
              Bordered="true"
              Striped="true"
              @ref="_table">
        <HeaderContent>
            <MudTh @onclick="() => ToggleSort(nameof(DepartmentViewModel.Id))" Style="cursor:pointer;">
                Id
                @SortIcon(nameof(DepartmentViewModel.Id))
            </MudTh>

            <MudTh @onclick="() => ToggleSort(nameof(DepartmentViewModel.Name))" Style="cursor:pointer;">
                Название
                @SortIcon(nameof(DepartmentViewModel.Name))
            </MudTh>

            <MudTh>Родитель</MudTh>
            <MudTh>Действия</MudTh>
        </HeaderContent>

        <RowTemplate>
            <MudTd DataLabel="Id">@context.Id</MudTd>
            <MudTd DataLabel="Название">@context.Name</MudTd>
            <MudTd DataLabel="Родитель">@GetParentName(context.ParentId)</MudTd>
            <MudTd DataLabel="Действия">
                <MudButton Size="Size.Small" Variant="Variant.Text" OnClick="(() => OpenEdit(context))">Редактировать</MudButton>
                <MudButton Size="Size.Small" Color="Color.Error" Variant="Variant.Text" OnClick="(() => Delete(context))">Удалить</MudButton>
            </MudTd>
        </RowTemplate>

        <PagerContent>
            <MudTablePager PageSizeOptions="new int[] { 10, 25, 50 }" />
        </PagerContent>
    </MudTable>
</MudStack>

<EditDepartmentDialog IsVisible="@isEditModalVisible"
                      IsVisibleChanged="@(async v => isEditModalVisible = v)"
                      Model="@editingModel"
                      Departments="@_items"
                      OnSaved="OnEditSaved" />

@code {
    private MudTable<DepartmentViewModel>? _table;
    private List<DepartmentViewModel> _items = new();
    private bool isEditModalVisible;
    private DepartmentViewModel? editingModel;

    private string _sortedColumn = null;
    private SortDirection _sortDirection = SortDirection.None;

    private Func<DepartmentViewModel, object>? _sortBy;
    private IEnumerable<DepartmentViewModel> _sortedItems => ApplySorting(_items);

    protected override async Task OnInitializedAsync()
    {
        await LoadItems();
    }

    private async Task LoadItems()
    {
        try
        {
            var resp = await AdminClient.DepartmentsGetAsync();
            var data = resp?.Data ?? new List<DepartmentResponse>();

            _items = data.Select(d => new DepartmentViewModel
            {
                Id = d.Id,
                Name = d.Name,
                ParentId = d.Parent != null ? d.Parent.Id : (int?)null
            }).ToList();

            _sortedColumn = null;
            _sortDirection = SortDirection.None;
            _sortBy = null;
        }
        catch (ApiException aex)
        {
            Snackbar.Add($"Ошибка API: {aex.Message}", Severity.Error);
            _items = new List<DepartmentViewModel>();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Ошибка загрузки: {ex.Message}", Severity.Error);
            _items = new List<DepartmentViewModel>();
        }
    }

    private IEnumerable<DepartmentViewModel> ApplySorting(List<DepartmentViewModel> items)
    {
        if (_sortBy == null || _sortDirection == SortDirection.None)
            return items;

        return _sortDirection == SortDirection.Ascending
            ? items.OrderBy(_sortBy)
            : items.OrderByDescending(_sortBy);
    }

    private void ToggleSort(string propertyName)
    {
        if (_sortedColumn == propertyName)
        {
            switch (_sortDirection)
            {
                case SortDirection.None:
                    _sortDirection = SortDirection.Ascending;
                    break;
                case SortDirection.Ascending:
                    _sortDirection = SortDirection.Descending;
                    break;
                case SortDirection.Descending:
                    _sortDirection = SortDirection.None;
                    break;
            }
        }
        else
        {
            _sortedColumn = propertyName;
            _sortDirection = SortDirection.Ascending;
        }

        _sortBy = _sortDirection switch
        {
            SortDirection.Ascending or SortDirection.Descending => propertyName switch
            {
                nameof(DepartmentViewModel.Id) => item => item.Id ?? 0,
                nameof(DepartmentViewModel.Name) => item => item.Name ?? string.Empty,
                _ => null
            },
            _ => null
        };

        StateHasChanged();
    }

    private RenderFragment SortIcon(string propertyName) => builder =>
    {
        if (_sortedColumn != propertyName) return;

        var icon = _sortDirection switch
        {
            SortDirection.Ascending => Icons.Material.Filled.ArrowUpward,
            SortDirection.Descending => Icons.Material.Filled.ArrowDownward,
            _ => Icons.Material.Filled.UnfoldMore
        };

        builder.OpenComponent<MudIcon>(0);
        builder.AddAttribute(1, "Icon", icon);
        builder.AddAttribute(2, "Style", "margin-left: 8px; font-size: 1rem; vertical-align: middle;");
        builder.CloseComponent();
    };

    private string GetParentName(int? parentId)
    {
        if (parentId == null) return "-";
        var p = _items.FirstOrDefault(x => x.Id == parentId);
        return !string.IsNullOrWhiteSpace(p?.Name) ? p!.Name! : parentId.ToString() ?? "-";
    }

    private Task OpenCreate()
    {
        editingModel = new DepartmentViewModel();
        isEditModalVisible = true;
        return Task.CompletedTask;
    }

    private Task OpenEdit(DepartmentViewModel item)
    {
        editingModel = new DepartmentViewModel { Id = item.Id, Name = item.Name, ParentId = item.ParentId };
        isEditModalVisible = true;
        return Task.CompletedTask;
    }

    private async Task OnEditSaved(bool saved)
    {
        isEditModalVisible = false;
        if (saved)
        {
            await LoadItems();
            Snackbar.Add("Сохранено", Severity.Success);
        }
    }

    private async Task Delete(DepartmentViewModel item)
    {
        bool? confirm = await DialogService.ShowMessageBoxAsync("Подтвердите", $"Удалить отдел «{item.Name}»?", yesText: "Да", noText: "Нет");
        if (confirm == true)
        {
            try
            {
                await AdminClient.DepartmentsDeleteAsync(item.Id ?? 0);
                await LoadItems();
                Snackbar.Add("Удалено", Severity.Success);
            }
            catch (ApiException ex)
            {
                Snackbar.Add($"Ошибка удаления: {ex.Message}", Severity.Error);
            }
        }
    }
}