@page "/login"
@inject IAuthService AuthService
@inject IApiErrorHandler ErrorHandler
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<MudPaper Class="d-flex flex-column mx-auto mt-12 pa-6" Elevation="8" Style="max-width: 400px;">
    <MudText Typo="Typo.h5" Class="mb-4 text-center">Вход в систему</MudText>

    <MudForm @ref="_form">
        <MudTextField @bind-Value="_model.Email"
                      Label="Email"
                      For="@(() => _model.Email)"
                      Required="true"
                      InputType="InputType.Email"
                      RequiredError="Введите Email"
                      Class="mb-3" />

        <MudTextField @bind-Value="_model.Password"
                      Label="Пароль"
                      For="@(() => _model.Password)"
                      Required="true"
                      InputType="InputType.Password"
                      RequiredError="Введите пароль"
                      Class="mb-4" />

        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   Class="w-100"
                   Disabled="@_loading"
                   OnClick="SubmitAsync">
            @(_loading ? "Вход..." : "Войти")
        </MudButton>
    </MudForm>
</MudPaper>

@code {
    private MudForm? _form;
    private bool _loading = false;
    private LoginRequest _model = new();

    private async Task SubmitAsync()
    {
        if (_form == null) return;

        await _form.ValidateAsync();
        if (!_form.IsValid) return;

        _loading = true;
        StateHasChanged();

        try
        {
            await AuthService.LoginAsync(_model);

            Snackbar.Add("Успешный вход", Severity.Success);
            Nav.NavigateTo("/");
        }
        catch (ApiException ex)
        {
            var message = ErrorHandler.GetErrorMessage(ex);
            Snackbar.Add(message, Severity.Error, config => config.VisibleStateDuration = 5000);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Неожиданная ошибка: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }
}