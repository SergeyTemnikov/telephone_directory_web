@inherits LayoutComponentBase
@inject ISnackbar Snackbar
@inject IAuthService AuthService
@inject NavigationManager Nav
@inject ILocalStorageService LocalStorage 
@using Microsoft.AspNetCore.Components.Authorization

<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <AppInitializer />
        <div class="top-row px-4 d-flex align-center justify-space-between">
            <MudText Typo="Typo.h6">Телефонный справочник</MudText>
            <AuthorizeView Context="authContext">
                <Authorized>
                    <div class="d-flex align-center gap-2">
                        <div class="d-flex align-center gap-2 px-2">
                            <MudMenu OffsetY="true">
                                <ActivatorContent>
                                    <MudIconButton Icon="@Icons.Material.Filled.AccountCircle"
                                                   Color="Color.Default"
                                                   Title="Профиль"
                                                   OnClick="@context.ToggleAsync"/>
                                </ActivatorContent>
                                <ChildContent>
                                    <MudMenuItem OnClick="LogoutAsync"
                                                 Icon="@Icons.Material.Filled.Logout"
                                                 Color="Color.Error">
                                        Выйти
                                    </MudMenuItem>
                                </ChildContent>
                            </MudMenu>
                        </div>
                    </div>
                </Authorized>
            </AuthorizeView>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

@code {
    private async Task LogoutAsync()
    {
        try
        {
            await AuthService.LogoutAsync();
            Snackbar.Add("Вы вышли из аккаунта", Severity.Info);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Ошибка выхода: {ex.Message}", Severity.Error);
        }
    }
}